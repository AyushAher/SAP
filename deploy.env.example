# Host deployment environment file
# Copy per environment to the deploy host:
#   UAT:  /home/ayush/services/sap-platform/.env.uat
#   Prod: /home/ayush/services/sap-platform/.env.prod
# Fallback: /home/ayush/services/sap-platform/.env
# Used by: docker stack deploy (sourced in GitHub Actions deploy workflow)
#
# Create separate GitHub Environments named "uat" and "prod" for registry secrets.
# Per-environment application secrets live in the host .env file below.
#
# =============================================================================
# REQUIRED CHECKLIST — deploy fails without these on the host
# =============================================================================
# [ ] File exists: /home/ayush/services/sap-platform/.env.uat  (or .env.prod)
# [ ] DB_CONNECTION          — PostgreSQL connection string (external to stack)
# [ ] SAP_SERVICE_LAYER_URL  — base URL only, e.g. https://192.168.0.6:50000 (no /b1s/v1)
# [ ] SAP_USERNAME           — SAP Service Layer user (Accounts[0])
# [ ] SAP_PASSWORD           — SAP Service Layer manager password (Accounts[0]; Hangfire refresh)
# [ ] SAP_COMPANY_DB         — SAP company database name (Accounts[0])
#     Optional extra DBs: SapCredentials__Accounts__1__Username/Password/CompanyDb in compose/env
# [ ] HMAC_SECRET            — API HMAC signing secret (openssl rand -hex 32)
# [ ] JWT_SECRET_KEY         — Base64-encoded 32-byte key (openssl rand -base64 32)
# [ ] CORS_ORIGIN            — UAT: http://<host>:8082  Prod: https://your-domain
#
# Optional:
# [ ] REDIS_CONNECTION       — defaults to redis:6379,abortConnect=false (no quotes)
# [ ] AES_KEY_BASE64         — Base64 AES-256 key (openssl rand -base64 32); optional
# [ ] DOCKER_REGISTRY        — defaults to ayushaher118
#
# RSA keys for encrypted login payloads:
#   - UI public key is baked into the sap-ui image at build time.
#   - API private key is baked into the sap-api image during CI build from either:
#       GitHub secret RSA_PRIVATE_KEY (uat/prod environment), or
#       /home/ayush/services/sap-platform/keys/private.pem on the deploy host.
#   - public.pem must match sap-ui/src/config/keys/public.pem.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Docker registry & image tags
# -----------------------------------------------------------------------------
DOCKER_REGISTRY=ayushaher118

# Image tag set automatically by deploy workflow per environment:
#   UAT  -> TAG=uat   (also pushed as uat-<short-sha>)
#   Prod -> TAG=prod  (also pushed as prod-<short-sha> and latest)
TAG=uat

# -----------------------------------------------------------------------------
# Shared infrastructure (PostgreSQL is external — not in the Docker stack)
# -----------------------------------------------------------------------------
# Quote optional for DB_CONNECTION; do not quote REDIS_CONNECTION (commas break parsing).
DB_CONNECTION=Host=postgres;Port=5432;Database=SapApi;Username=...;Password=...
REDIS_CONNECTION=redis:6379,abortConnect=false

# -----------------------------------------------------------------------------
# UAT example values
# -----------------------------------------------------------------------------
# SAP_SERVICE_LAYER_URL=https://192.168.0.6:50000
# SAP_USERNAME=manager
# SAP_PASSWORD=change-me-manager-password
# SAP_COMPANY_DB=PBBPL_UAT
# HMAC_SECRET=openssl rand -hex 32
# AES_KEY_BASE64=openssl rand -base64 32  (optional)
# JWT_SECRET_KEY=openssl rand -base64 32
# CORS_ORIGIN=http://your-host:8082

# -----------------------------------------------------------------------------
# Prod example values (use prod-specific secrets on the prod host .env)
# -----------------------------------------------------------------------------
# SAP_SERVICE_LAYER_URL=https://sap-prod-host:50000
# SAP_USERNAME=manager
# SAP_PASSWORD=change-me-manager-password
# SAP_COMPANY_DB=COMPANY_DB_PROD
# HMAC_SECRET=change-me-prod-long-random-string
# AES_KEY_BASE64=
# JWT_SECRET_KEY=base64-encoded-32-byte-key
# CORS_ORIGIN=https://sap.example.com

# Required for each environment (uncomment and set the block you need):
SAP_SERVICE_LAYER_URL=
SAP_USERNAME=
SAP_PASSWORD=
SAP_COMPANY_DB=
HMAC_SECRET=
AES_KEY_BASE64=
JWT_SECRET_KEY=
CORS_ORIGIN=
