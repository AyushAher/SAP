# Example nginx config for SAP UI static hosting.
# After `npm run build`, include dist/nginx-security-headers.conf in your server block.

server {
    listen 443 ssl http2;
    server_name sap-ui.example.com;

    root /var/www/sap-ui/dist;
    index index.html;

    # SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API reverse proxy (adjust upstream to your backend)
    location /api/ {
        proxy_pass http://localhost:5033/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    include /var/www/sap-ui/dist/nginx-security-headers.conf;
}
