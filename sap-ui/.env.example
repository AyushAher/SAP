# Copy to .env for production builds pointing at a remote API.
# In local dev, Vite proxies /api -> http://localhost:5033 (see vite.config.ts).
VITE_API_BASE_URL=/api

# Optional: CSP violation reports (connect-src is derived from VITE_API_BASE_URL).
# VITE_CSP_REPORT_URI=https://your-csp-report-endpoint.example.com/report
