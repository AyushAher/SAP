# =============================================================================
# UAT host environment file
# =============================================================================
# Copy to the deploy host:
#   /home/ayush/services/sap-platform/.env.uat
#
# Used by: docker stack deploy (sourced in GitHub Actions deploy workflow)
# Compose file: docker-compose.uat.yml
#
# Deploy workflow validates these REQUIRED vars (non-empty):
#   DB_CONNECTION, SAP_SERVICE_LAYER_URL, SAP_USERNAME, SAP_COMPANY_DB,
#   HMAC_SECRET, JWT_SECRET_KEY, CORS_ORIGIN
#
# RSA keys for encrypted login (not in this file):
#   - UI public key is baked into the sap-ui image at build time.
#   - API private key is baked into sap-api during CI from GitHub secret
#     RSA_PRIVATE_KEY (uat environment) or host file:
#     /home/ayush/services/sap-platform/keys/private.pem
# =============================================================================

# -----------------------------------------------------------------------------
# Docker registry & image tags
# -----------------------------------------------------------------------------
# Registry username/org (GitHub secret DOCKER_REGISTRY overrides at deploy time)
DOCKER_REGISTRY=ayushaher118

# Image tag — deploy workflow sets TAG=uat automatically; keep uat for manual deploys
TAG=uat

# -----------------------------------------------------------------------------
# Database (PostgreSQL — external to Docker stack)
# -----------------------------------------------------------------------------
# Replace host, username, and password with your UAT PostgreSQL instance.
# Database name matches SapApi default: SapApi
DB_CONNECTION=Host=192.168.0.5;Port=5432;Database=SapApi;Username=postgres;Password='f3ron63GL@';Pooling=true;MinPoolSize=5;MaxPoolSize=100;Connection Idle Lifetime=300;Connection Pruning Interval=10

# -----------------------------------------------------------------------------
# Redis (in-stack service — use Docker service name)
# -----------------------------------------------------------------------------
# Default matches docker-compose.uat.yml redis service on sap-platform-uat network.
# Do not wrap in quotes — abortConnect=false must not become false".
REDIS_CONNECTION=redis:6379,abortConnect=false

# -----------------------------------------------------------------------------
# SAP Business One Service Layer
# -----------------------------------------------------------------------------
# Base URL only — do NOT append /b1s/v1 (API adds it automatically)
# UAT default from appsettings.json (update host/IP for your environment):
SAP_SERVICE_LAYER_URL=https://192.168.0.6:50000

# SAP Service Layer login user (company DB context, not app user password)
SAP_USERNAME=manager

# UAT company database name from appsettings.json:
SAP_COMPANY_DB=PBBPL_UAT

# -----------------------------------------------------------------------------
# Security secrets — generate unique values for UAT; never reuse prod secrets
# -----------------------------------------------------------------------------
# HMAC signing secret (long random string, >= 32 chars recommended)
# Generate: openssl rand -hex 32
HMAC_SECRET=CHANGE_ME_uat_hmac_secret_openssl_rand_hex_32



# -----------------------------------------------------------------------------
# CORS — must match the browser origin hitting sap-ui on UAT (port 8082)
# -----------------------------------------------------------------------------
# Replace YOUR_DEPLOY_HOST with the server hostname or IP users open in the browser
CORS_ORIGIN=http://192.168.0.5:8082
